{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://directive-workspace.dev/schemas/standalone-host-config.schema.json",
  "title": "Directive Workspace Standalone Host Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "directiveRoot"
  ],
  "properties": {
    "mode": {
      "type": "string",
      "const": "standalone_reference_api_host"
    },
    "directiveRoot": {
      "type": "string",
      "minLength": 1
    },
    "receivedAt": {
      "type": "string",
      "minLength": 1
    },
    "unresolvedGapIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "initialQueue": {
      "type": "object"
    },
    "server": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "none",
            "static_bearer"
          ]
        },
        "bearerToken": {
          "type": "string",
          "minLength": 1
        },
        "bearerTokenEnvName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "filesystem",
            "filesystem_and_sqlite"
          ]
        },
        "sqlitePath": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "runtimeArtifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "relativeRoot": {
          "type": "string",
          "minLength": 1
        },
        "writeStatusFile": {
          "type": "boolean"
        },
        "writeAccessLog": {
          "type": "boolean"
        },
        "writeBootLog": {
          "type": "boolean"
        }
      }
    }
  }
}
