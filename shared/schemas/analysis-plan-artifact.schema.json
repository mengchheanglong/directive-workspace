{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "directive-workspace/schemas/analysis-plan-artifact",
  "title": "AnalysisPlanArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "analysis_hypothesis",
    "stage_plan",
    "decision_criteria",
    "risk_notes"
  ],
  "properties": {
    "capability_id": {
      "type": "string",
      "minLength": 1
    },
    "analysis_hypothesis": {
      "type": "string",
      "minLength": 1
    },
    "stage_plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decision_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risk_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
