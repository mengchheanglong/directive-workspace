{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "directive-workspace/schemas/discovery-fast-path-record-request",
  "title": "DiscoveryFastPathRecordRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_id",
    "candidate_name",
    "record_date",
    "source_type",
    "source_reference",
    "claimed_value",
    "first_pass_summary",
    "adoption_target",
    "decision_state",
    "route_destination",
    "why_this_route",
    "why_not_alternatives",
    "need_bounded_proof",
    "next_artifact"
  ],
  "properties": {
    "candidate_id": { "type": "string", "minLength": 1 },
    "candidate_name": { "type": "string", "minLength": 1 },
    "record_date": { "type": "string", "format": "date" },
    "source_type": {
      "type": "string",
      "enum": [
        "github-repo",
        "paper",
        "product-doc",
        "theory",
        "technical-essay",
        "workflow-writeup",
        "external-system",
        "internal-signal"
      ]
    },
    "source_reference": { "type": "string", "minLength": 1 },
    "claimed_value": { "type": "string", "minLength": 1 },
    "first_pass_summary": { "type": "string", "minLength": 1 },
    "adoption_target": { "type": "string", "minLength": 1 },
    "decision_state": {
      "type": "string",
      "enum": ["adopt", "defer", "monitor", "reject"]
    },
    "route_destination": {
      "type": "string",
      "enum": ["forge", "architecture", "monitor", "defer", "reject", "reference"]
    },
    "why_this_route": { "type": "string", "minLength": 1 },
    "why_not_alternatives": { "type": "string", "minLength": 1 },
    "need_bounded_proof": { "type": "string", "minLength": 1 },
    "next_artifact": { "type": "string", "minLength": 1 },
    "source_location_on_disk": { "type": ["string", "null"] },
    "stack_language": { "type": ["string", "null"] },
    "stack_runtime": { "type": ["string", "null"] },
    "stack_framework": { "type": ["string", "null"] },
    "stack_package_tool": { "type": ["string", "null"] },
    "stack_deployment": { "type": ["string", "null"] },
    "stack_external_dependencies": { "type": ["string", "null"] },
    "stack_data_model_assumptions": { "type": ["string", "null"] },
    "stack_integration_shape": { "type": ["string", "null"] },
    "compaction_profile": { "type": ["string", "null"] },
    "compaction_status": {
      "type": ["string", "null"],
      "enum": ["full", "compacted", "bypass", null]
    },
    "compaction_reason": { "type": ["string", "null"] },
    "reentry_trigger": { "type": ["string", "null"] },
    "review_cadence": { "type": ["string", "null"] },
    "mission_alignment": { "type": ["string", "null"] },
    "capability_gap_id": { "type": ["string", "null"] },
    "gap_worklist_rank": { "type": ["string", "null"] },
    "output_relative_path": { "type": ["string", "null"] }
  }
}
