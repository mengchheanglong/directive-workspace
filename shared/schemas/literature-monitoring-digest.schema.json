{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "directive-workspace/literature-monitoring-digest",
  "title": "LiteratureMonitoringDigest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "candidate_id",
    "generated_at",
    "topic_input",
    "degraded",
    "provider_snapshot",
    "accepted_candidates",
    "digest_summary",
    "evidence_quality_result",
    "delivery_target"
  ],
  "properties": {
    "artifact_type": {
      "const": "literature_monitoring_digest"
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "topic_input": {
      "type": "string",
      "minLength": 1
    },
    "degraded": {
      "const": false
    },
    "provider_snapshot": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "provider",
          "status",
          "candidate_count"
        ],
        "properties": {
          "provider": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "candidate_count": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "accepted_candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "source_ref",
          "ranking_reason",
          "evidence_quality"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "source_ref": {
            "type": "string",
            "minLength": 1
          },
          "ranking_reason": {
            "type": "string",
            "minLength": 1
          },
          "evidence_quality": {
            "type": "string",
            "enum": [
              "pass",
              "degraded_quality"
            ]
          }
        }
      }
    },
    "digest_summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence_quality_result": {
      "type": "string",
      "enum": [
        "pass",
        "degraded_quality"
      ]
    },
    "delivery_target": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
