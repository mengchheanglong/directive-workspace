{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "directive-workspace/schemas/experiment-design-artifact",
  "title": "ExperimentDesignArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "bounded_scope",
    "validation_commands",
    "rollback_plan",
    "expected_outputs"
  ],
  "properties": {
    "capability_id": {
      "type": "string",
      "minLength": 1
    },
    "bounded_scope": {
      "type": "string",
      "minLength": 1
    },
    "validation_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^npm run "
      }
    },
    "rollback_plan": {
      "type": "string",
      "minLength": 1
    },
    "expected_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
