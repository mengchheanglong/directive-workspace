{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "directive-workspace/schemas/integration-contract-artifact",
  "title": "IntegrationContractArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "adoption_target",
    "integration_mode",
    "required_gates",
    "owner"
  ],
  "properties": {
    "capability_id": {
      "type": "string",
      "minLength": 1
    },
    "adoption_target": {
      "type": "string",
      "minLength": 1
    },
    "integration_mode": {
      "type": "string",
      "enum": [
        "reimplement",
        "adapt",
        "wrap"
      ]
    },
    "required_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^npm run "
      }
    },
    "owner": {
      "type": "string",
      "minLength": 1
    }
  }
}
