{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "directive-workspace/schemas/intake-normalized-artifact",
  "title": "IntakeNormalizedArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "source_type",
    "source_ref",
    "normalization_status",
    "normalized_payload"
  ],
  "properties": {
    "capability_id": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "minLength": 1
    },
    "source_ref": {
      "type": "string",
      "minLength": 1
    },
    "normalization_status": {
      "type": "string",
      "enum": [
        "complete",
        "partial",
        "failed"
      ]
    },
    "normalized_payload": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true
    }
  }
}
