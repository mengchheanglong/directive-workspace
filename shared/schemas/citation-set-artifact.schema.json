{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "directive-workspace/schemas/citation-set-artifact",
  "title": "CitationSetArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "citations",
    "reference_section_markdown",
    "coverage_status"
  ],
  "properties": {
    "capability_id": {
      "type": "string",
      "minLength": 1
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string",
            "minLength": 1,
            "format": "uri",
            "pattern": "^https?://"
          },
          "title": {
            "type": "string"
          }
        }
      }
    },
    "reference_section_markdown": {
      "type": "string",
      "minLength": 1
    },
    "coverage_status": {
      "type": "string",
      "enum": [
        "complete",
        "partial",
        "missing"
      ]
    }
  }
}
