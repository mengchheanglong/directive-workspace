{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "directive-workspace/schemas/evaluation-support-artifact",
  "title": "EvaluationSupportArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "source_urls",
    "visited_urls",
    "research_costs",
    "quality_signals"
  ],
  "properties": {
    "capability_id": {
      "type": "string",
      "minLength": 1
    },
    "source_urls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "visited_urls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "research_costs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_usd"
      ],
      "properties": {
        "total_usd": {
          "type": "number",
          "minimum": 0
        },
        "provider_breakdown": {
          "type": "object",
          "additionalProperties": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    },
    "quality_signals": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "evidence_coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "citation_coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
