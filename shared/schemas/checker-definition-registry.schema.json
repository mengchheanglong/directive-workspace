{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://directive-workspace.local/shared/schemas/checker-definition-registry.schema.json",
  "title": "Directive Workspace Checker Definition Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "schemaRef",
    "owningLane",
    "definitions"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "schemaRef": {
      "type": "string",
      "const": "shared/schemas/checker-definition-registry.schema.json"
    },
    "owningLane": {
      "type": "string",
      "const": "architecture"
    },
    "registryIntent": {
      "type": "string",
      "enum": [
        "bounded_pilot"
      ]
    },
    "pilotPolicy": {
      "$ref": "#/$defs/pilotPolicy"
    },
    "definitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/checkerDefinition"
      }
    }
  },
  "$defs": {
    "pilotPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxDefinitions",
        "approvedCheckerIds"
      ],
      "properties": {
        "maxDefinitions": {
          "type": "integer",
          "minimum": 1
        },
        "approvedCheckerIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "proofExpectation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "mustInclude"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "json_summary"
          ]
        },
        "mustInclude": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredJsonPaths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/jsonPathExpectation"
          }
        }
      }
    },
    "jsonPathExpectation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "equals"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "equals": {
          "type": [
            "string",
            "number",
            "boolean"
          ]
        }
      }
    },
    "checkerDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkerId",
        "npmScript",
        "entryPoint",
        "targetSurface",
        "purpose",
        "successSemantics",
        "failureSemantics",
        "proofExpectation"
      ],
      "properties": {
        "checkerId": {
          "type": "string",
          "minLength": 1
        },
        "npmScript": {
          "type": "string",
          "pattern": "^check:"
        },
        "entryPoint": {
          "type": "string",
          "pattern": "^scripts/.+\\.ts$"
        },
        "targetSurface": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "successSemantics": {
          "type": "string",
          "minLength": 1
        },
        "failureSemantics": {
          "type": "string",
          "minLength": 1
        },
        "failureExpectation": {
          "$ref": "#/$defs/failureExpectation"
        },
        "proofExpectation": {
          "$ref": "#/$defs/proofExpectation"
        }
      }
    },
    "failureExpectation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "probeArgs",
        "expectedExitCode",
        "requiredJsonPaths"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "json_failure_probe"
          ]
        },
        "probeArgs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "expectedExitCode": {
          "type": "integer",
          "minimum": 1
        },
        "requiredJsonPaths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/jsonPathExpectation"
          }
        }
      }
    }
  }
}
