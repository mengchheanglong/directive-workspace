{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "directive-workspace/schemas/discovery-case-record-request",
  "title": "DiscoveryCaseRecordRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_id",
    "candidate_name",
    "intake",
    "triage",
    "routing"
  ],
  "properties": {
    "candidate_id": { "type": "string", "minLength": 1 },
    "candidate_name": { "type": "string", "minLength": 1 },
    "intake": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intake_date",
        "source_type",
        "source_reference",
        "submitted_by",
        "why_it_entered_the_system",
        "claimed_value",
        "initial_relevance_to_workspace",
        "suspected_adoption_target"
      ],
      "properties": {
        "intake_date": { "type": "string", "format": "date" },
        "source_type": {
          "type": "string",
          "enum": [
            "github-repo",
            "paper",
            "product-doc",
            "theory",
            "technical-essay",
            "workflow-writeup",
            "external-system",
            "internal-signal"
          ]
        },
        "source_reference": { "type": "string", "minLength": 1 },
        "submitted_by": { "type": "string", "minLength": 1 },
        "why_it_entered_the_system": { "type": "string", "minLength": 1 },
        "claimed_value": { "type": "string", "minLength": 1 },
        "initial_relevance_to_workspace": { "type": "string", "minLength": 1 },
        "suspected_adoption_target": { "type": "string", "minLength": 1 },
        "source_location_on_disk": { "type": ["string", "null"] },
        "stack_language": { "type": ["string", "null"] },
        "stack_runtime": { "type": ["string", "null"] },
        "stack_framework": { "type": ["string", "null"] },
        "stack_package_tool": { "type": ["string", "null"] },
        "stack_deployment": { "type": ["string", "null"] },
        "stack_external_dependencies": { "type": ["string", "null"] },
        "stack_data_model_assumptions": { "type": ["string", "null"] },
        "stack_integration_shape": { "type": ["string", "null"] },
        "immediate_notes": { "type": ["string", "null"] },
        "output_relative_path": { "type": ["string", "null"] }
      }
    },
    "triage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "triage_date",
        "first_pass_summary",
        "problem_it_appears_to_solve",
        "extractable_value_hypothesis",
        "routing_recommendation",
        "proposed_adoption_target",
        "stack_shape_summary",
        "boilerplate_vs_product_boundary",
        "suggested_decision_state",
        "fit_to_current_direction",
        "reusability_across_surfaces",
        "operational_risk",
        "integration_cost",
        "can_current_gates_validate_safely",
        "immediate_risks",
        "missing_evidence",
        "next_action"
      ],
      "properties": {
        "triage_date": { "type": "string", "format": "date" },
        "first_pass_summary": { "type": "string", "minLength": 1 },
        "problem_it_appears_to_solve": { "type": "string", "minLength": 1 },
        "extractable_value_hypothesis": { "type": "string", "minLength": 1 },
        "routing_recommendation": { "type": "string", "minLength": 1 },
        "proposed_adoption_target": { "type": "string", "minLength": 1 },
        "stack_shape_summary": { "type": "string", "minLength": 1 },
        "boilerplate_vs_product_boundary": { "type": "string", "minLength": 1 },
        "suggested_decision_state": { "type": "string", "minLength": 1 },
        "fit_to_current_direction": { "type": "string", "minLength": 1 },
        "reusability_across_surfaces": { "type": "string", "minLength": 1 },
        "operational_risk": { "type": "string", "minLength": 1 },
        "integration_cost": { "type": "string", "minLength": 1 },
        "can_current_gates_validate_safely": { "type": "string", "minLength": 1 },
        "immediate_risks": { "type": "string", "minLength": 1 },
        "missing_evidence": { "type": "string", "minLength": 1 },
        "next_action": { "type": "string", "minLength": 1 },
        "monitor_defer_trigger_conditions": { "type": ["string", "null"] },
        "reentry_conditions": { "type": ["string", "null"] },
        "output_relative_path": { "type": ["string", "null"] }
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_date",
        "source_type",
        "decision_state",
        "adoption_target",
        "route_destination",
        "why_this_route",
        "why_not_alternatives",
        "receiving_track_owner",
        "required_next_artifact"
      ],
      "properties": {
        "route_date": { "type": "string", "format": "date" },
        "source_type": {
          "type": "string",
          "enum": [
            "github-repo",
            "paper",
            "product-doc",
            "theory",
            "technical-essay",
            "workflow-writeup",
            "external-system",
            "internal-signal"
          ]
        },
        "decision_state": {
          "type": "string",
          "enum": ["adopt", "defer", "monitor", "reject"]
        },
        "adoption_target": { "type": "string", "minLength": 1 },
        "route_destination": {
          "type": "string",
          "enum": ["runtime", "architecture", "monitor", "defer", "reject", "reference"]
        },
        "why_this_route": { "type": "string", "minLength": 1 },
        "why_not_alternatives": { "type": "string", "minLength": 1 },
        "receiving_track_owner": { "type": "string", "minLength": 1 },
        "required_next_artifact": { "type": "string", "minLength": 1 },
        "handoff_contract_used": { "type": ["string", "null"] },
        "reentry_or_promotion_conditions": { "type": ["string", "null"] },
        "review_cadence": { "type": ["string", "null"] },
        "output_relative_path": { "type": ["string", "null"] }
      }
    },
    "completion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_date",
        "decision_state",
        "adoption_target",
        "route_destination",
        "rationale",
        "evidence_path",
        "validation_method",
        "rollback_note",
        "output_relative_path"
      ],
      "properties": {
        "decision_date": { "type": "string", "format": "date" },
        "decision_state": {
          "type": "string",
          "enum": ["adopt", "defer", "monitor", "reject"]
        },
        "adoption_target": { "type": "string", "minLength": 1 },
        "route_destination": {
          "type": "string",
          "enum": ["runtime", "architecture", "monitor", "defer", "reject", "reference"]
        },
        "rationale": { "type": "string", "minLength": 1 },
        "evidence_path": { "type": "string", "minLength": 1 },
        "validation_method": { "type": "string", "minLength": 1 },
        "rollback_note": { "type": "string", "minLength": 1 },
        "output_relative_path": { "type": "string", "minLength": 1 },
        "excluded_baggage": { "type": ["string", "null"] },
        "risk_note": { "type": ["string", "null"] },
        "follow_up_owner": { "type": ["string", "null"] },
        "follow_up_path": { "type": ["string", "null"] }
      }
    }
  }
}
