    "partition_date": { "type": "string" },
    "source_id": { "type": "string" },
    "source_reference": { "type": "array", "items": { "type": "string" } },
    "packet_inputs_reused": { "type": "array", "items": { "type": "string" } },
    "packet_coverage_scope": { "type": "array", "items": { "type": "string" } },
    "source_reanalysis_required": { "type": "array", "items": { "type": "string" } },
    "architecture_retained_mechanisms": { "type": "array", "items": { "type": "string" } },
