    "split_rationale": { "type": "string" },
    "architecture_artifact_targets": { "type": "array", "items": { "type": "string" } },
    "forge_handoff_candidates": { "type": "array", "items": { "type": "string" } },
    "defer_or_revisit_conditions": { "type": "array", "items": { "type": "string" } }
