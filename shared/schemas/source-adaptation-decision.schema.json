{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Source Adaptation Decision",
  "description": "Machine-readable schema for the extract → adapt → improve decision chain. Enforces the source-analysis-contract and adaptation-decision-contract.",
  "type": "object",
  "required": [
    "source_id",
    "analysis_date",
    "active_mission_ref",
    "usefulness_level",
    "mechanisms",
    "meta_usefulness",
    "decision_summary"
  ],
  "properties": {
    "source_id": {
      "type": "string",
      "description": "Candidate id or name"
    },
    "source_type": {
      "type": "string",
      "enum": ["github-repo", "paper", "framework", "tool", "workflow", "method", "other"]
    },
    "source_reference": {
      "type": "string",
      "description": "URL, DOI, or path"
    },
    "analysis_date": {
      "type": "string",
      "format": "date"
    },
    "active_mission_ref": {
      "type": "string",
      "description": "Reference to the active-mission document at time of analysis"
    },
    "usefulness_level": {
      "type": "string",
      "enum": ["direct", "structural", "meta"]
    },
    "capability_gap_addressed": {
      "type": "string",
      "description": "Which known capability gap this source helps close, if any"
    },
    "mechanisms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "mechanism_id",
          "extraction_decision",
          "adaptation_decision",
          "improvement_decision"
        ],
        "properties": {
          "mechanism_id": {
            "type": "string"
          },
          "value_type": {
            "type": "string",
            "enum": ["pattern", "policy", "schema", "contract", "algorithm", "workflow"]
          },
          "value_density": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "extraction_decision": {
            "type": "string",
            "enum": ["extract", "skip", "defer"]
          },
          "extraction_rationale": {
            "type": "string"
          },
          "target_artifact_type": {
            "type": "string",
            "enum": ["contract", "schema", "template", "policy", "reference-pattern", "shared-lib", "doctrine-update"]
          },
          "target_path": {
            "type": "string"
          },
          "adaptation_decision": {
            "type": "object",
            "required": ["required", "original_vs_adapted_delta"],
            "properties": {
              "required": {
                "type": "string",
                "enum": ["yes", "no", "minimal"]
              },
              "actions": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "terminology_alignment",
                    "structural_reshape",
                    "simplify",
                    "extend",
                    "constrain",
                    "recompose"
                  ]
                }
              },
              "description": {
                "type": "string"
              },
              "original_vs_adapted_delta": {
                "type": "string",
                "description": "Mandatory: what changed between original and adapted form"
              }
            }
          },
          "improvement_decision": {
            "type": "object",
            "required": ["applied", "original_vs_improved_delta"],
            "properties": {
              "applied": {
                "type": "string",
                "enum": ["yes", "no"]
              },
              "type": {
                "type": "string",
                "enum": ["quality", "efficiency", "safety", "generality", "composability", "evaluability"]
              },
              "description": {
                "type": "string"
              },
              "original_vs_improved_delta": {
                "type": "string",
                "description": "Mandatory: what the improved form does that the original does not"
              },
              "evidence_plan": {
                "type": "string"
              }
            }
          },
          "baggage_excluded": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "element": { "type": "string" },
                "baggage_type": {
                  "type": "string",
                  "enum": ["implementation", "stack", "scope", "complexity"]
                },
                "reason": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "meta_usefulness": {
      "type": "object",
      "required": ["improves_source_consumption"],
      "properties": {
        "improves_source_consumption": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "analysis_quality",
            "extraction_quality",
            "adaptation_quality",
            "improvement_quality",
            "routing_quality",
            "evaluation_quality",
            "handoff_quality",
            "none"
          ]
        }
      }
    },
    "decision_summary": {
      "type": "object",
      "required": [
        "adaptation_quality",
        "improvement_quality",
        "confidence",
        "next_action"
      ],
      "properties": {
        "adaptation_quality": {
          "type": "string",
          "enum": ["strong", "adequate", "weak", "skipped"]
        },
        "improvement_quality": {
          "type": "string",
          "enum": ["strong", "adequate", "weak", "skipped"]
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "next_action": {
          "type": "string",
          "enum": ["proceed_to_proof", "needs_revision", "defer", "abandon"]
        },
        "verdict_rationale": {
          "type": "string"
        }
      }
    },
    "integration_target": {
      "type": "object",
      "properties": {
        "surface": {
          "type": "string",
          "enum": [
            "shared/contracts",
            "shared/schemas",
            "shared/templates",
            "architecture/05-reference-patterns",
            "knowledge",
            "shared/lib"
          ]
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forge_handoff_required": {
          "type": "boolean"
        },
        "forge_handoff_ref": {
          "type": "string"
        }
      }
    }
  }
}
