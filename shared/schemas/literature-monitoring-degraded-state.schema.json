{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "directive-workspace/literature-monitoring-degraded-state",
  "title": "LiteratureMonitoringDegradedState",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "candidate_id",
    "generated_at",
    "topic_input",
    "degraded",
    "degraded_reason",
    "provider_snapshot",
    "candidate_pool_count",
    "evidence_quality_result",
    "withheld_delivery",
    "next_safe_action"
  ],
  "properties": {
    "artifact_type": {
      "const": "literature_monitoring_degraded_state"
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "topic_input": {
      "type": "string",
      "minLength": 1
    },
    "degraded": {
      "const": true
    },
    "degraded_reason": {
      "type": "string",
      "minLength": 1
    },
    "provider_snapshot": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "provider",
          "status",
          "candidate_count"
        ],
        "properties": {
          "provider": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "candidate_count": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "candidate_pool_count": {
      "type": "integer",
      "minimum": 0
    },
    "evidence_quality_result": {
      "type": "string",
      "enum": [
        "degraded_quality",
        "fail"
      ]
    },
    "withheld_delivery": {
      "const": true
    },
    "next_safe_action": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
