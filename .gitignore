# Product-local rebuildable dependencies and frontend build output
/node_modules/
/frontend/node_modules/
/frontend/dist/

# Local frontend/dev caches
/frontend/.vite/
**/.vite/
*.tsbuildinfo

# Local machine/editor junk inside Directive Workspace only
**/.DS_Store
**/Thumbs.db
**/Desktop.ini
**/.vscode/
**/.idea/

# Local Python caches and experiment virtualenvs
**/__pycache__/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.venv/
**/.venv-*/

# Local env overrides only; examples stay trackable
/.env
/.env.local
/.env.development.local
/.env.test.local
/.env.production.local
/frontend/.env
/frontend/.env.local
/frontend/.env.development.local
/frontend/.env.test.local
/frontend/.env.production.local
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Standalone host local SQLite ledger; product proof artifacts remain trackable
/runtime/standalone-host/*.sqlite
/runtime/standalone-host/*.sqlite-*
/runtime/standalone-host/*.db

