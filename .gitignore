# Product-local rebuildable dependencies and frontend build output
/node_modules/
/frontend/node_modules/
/frontend/dist/

# Local frontend/dev caches
/frontend/.vite/
**/.vite/
*.tsbuildinfo

# Local machine/editor junk inside Directive Workspace only
**/.DS_Store
**/Thumbs.db
**/Desktop.ini
**/.vscode/
**/.idea/
*.bak
*.tmp
*.old
*.orig

# Local Python caches and experiment virtualenvs
**/__pycache__/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.venv/
**/.venv-*/
/scratch/venvs/

# Local env overrides only; examples stay trackable
/.env
/.env.local
/.env.development.local
/.env.test.local
/.env.production.local
/frontend/.env
/frontend/.env.local
/frontend/.env.development.local
/frontend/.env.test.local
/frontend/.env.production.local
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Standalone host local SQLite ledger; product proof artifacts remain trackable
/runtime/standalone-host/*.sqlite
/runtime/standalone-host/*.sqlite-*
/runtime/standalone-host/*.db

# System-only clone boundary.
# These rules keep future project-specific records, mutable workspace state, and
# local source/reference corpora out of clone-and-wire use. Existing tracked
# history is unchanged; this only suppresses new untracked churn.

# Local external source/reference copies
/sources/

# Generated control logs and operator reports
/control/logs/
/control/reports/

# Mutable whole-workspace state snapshots
/control/state/completion-status.json
/control/state/coordination-ledger.json
/control/state/operator-simplicity-migration-status.json
/control/state/wrapup-source-disposition.json
/discovery/intake-queue.json
/state/case-events/
/state/cases/

# Discovery lane records
/discovery/01-intake/
/discovery/02-triage/
/discovery/03-routing-log/
/discovery/04-monitor/
/discovery/05-deferred-or-rejected/

# Architecture lane records
/architecture/01-experiments/
/architecture/02-adopted/
/architecture/03-deferred-or-rejected/
/architecture/04-materialization/

