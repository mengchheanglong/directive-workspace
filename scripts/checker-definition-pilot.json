    {
      "checkerId": "case_planner_parity",
      "npmScript": "check:case-planner-parity",
      "entryPoint": "scripts/check-case-planner-parity.ts",
      "targetSurface": "Mirrored case planning parity across routed Discovery, Architecture, and Runtime stop boundaries",
      "purpose": "Keep planner next-step outcomes deterministic and aligned with authoritative mirrored case state.",
      "successSemantics": "Exit zero after replaying the golden parity set and emit a bounded JSON summary with both positive and blocked planner outcomes.",
      "failureSemantics": "Fail closed with `ok: false`, failureContractVersion `1`, and structured violations when mirrored snapshot planning drifts from the authoritative bounded outcomes.",
