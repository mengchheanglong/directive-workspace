      "purpose": "Preserve staged Engine reasoning boundaries and Architecture routing behavior for structural sources.",
      "successSemantics": "Exit zero after replaying the staged Engine control cases and emit a bounded JSON summary.",
      "failureSemantics": "Fail closed with `ok: false`, failureContractVersion `1`, and structured violations when staged routing or proof chaining regresses.",
      "failureExpectation": {
        "kind": "json_failure_probe",
        "probeArgs": [
          "--probe=structural_control_runtime_skew"
        ],
        "expectedExitCode": 1,
        "requiredJsonPaths": [
          {
            "path": "ok",
            "equals": false
          },
          {
            "path": "checkerId",
            "equals": "directive_engine_stage_chaining"
          },
          {
            "path": "failureContractVersion",
            "equals": 1
          },
          {
