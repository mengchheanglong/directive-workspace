          {
            "path": "violations.0.expected",
            "equals": "architecture"
          },
          {
            "path": "violations.0.actual",
            "equals": "runtime"
          }
        ]
      },
      "proofExpectation": {
        "kind": "json_summary",
        "mustInclude": [
          "\"ok\": true",
          "\"selectedLane\": \"architecture\"",
          "\"runtimeControl\": {"
