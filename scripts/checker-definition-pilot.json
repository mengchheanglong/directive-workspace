{
  "schemaVersion": 1,
  "schemaRef": "shared/schemas/checker-definition-registry.schema.json",
  "owningLane": "architecture",
  "registryIntent": "bounded_pilot",
  "pilotPolicy": {
    "maxDefinitions": 3,
    "approvedCheckerIds": [
      "control_authority",
      "directive_engine_stage_chaining",
      "case_planner_parity"
    ]
  },
  "definitions": [
    {
      "checkerId": "control_authority",
      "npmScript": "check:control-authority",
      "entryPoint": "scripts/check-control-authority.ts",
      "targetSurface": "Directive Workspace control entrypoint and active control surfaces",
      "purpose": "Keep the thin control entrypoint and required run-control surfaces aligned.",
      "successSemantics": "Exit zero after verifying the required control surfaces and emit a bounded JSON summary.",
      "failureSemantics": "Fail closed with `ok: false`, failureContractVersion `1`, and structured violations when required control content drifts.",
      "failureExpectation": {
        "kind": "json_failure_probe",
        "probeArgs": [
          "--probe=missing_required_content"
        ],
        "expectedExitCode": 1,
        "requiredJsonPaths": [
          {
            "path": "ok",
            "equals": false
          },
          {
            "path": "checkerId",
            "equals": "control_authority"
          },
          {
            "path": "failureContractVersion",
            "equals": 1
          },
          {
            "path": "violations.0.code",
            "equals": "missing_required_content"
          },
          {
            "path": "violations.0.path",
            "equals": "implement.md"
          }
        ]
      },
      "proofExpectation": {
        "kind": "json_summary",
        "mustInclude": [
          "\"ok\": true",
          "\"implementSectionCount\": 1"
        ],
        "requiredJsonPaths": [
          {
            "path": "ok",
            "equals": true
          },
          {
            "path": "checked.implement",
            "equals": "implement.md"
          },
          {
            "path": "checked.implementSectionCount",
            "equals": 1
          }
        ]
      }
    },
    {
